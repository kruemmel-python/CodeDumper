# CodeDumper local LLM defaults for Vite/React.
# Copy this file to .env.local and restart `npm run dev`.

# Recommended browser mode:
# Use a same-origin Vite proxy to avoid LM Studio CORS/preflight failures.
VITE_CODEDUMPER_LMSTUDIO_BASE_URL=/__codedumper_lmstudio

# Vite forwards /__codedumper_lmstudio/* to this LM Studio server.
# Change to your LAN IP if LM Studio runs on another machine.
VITE_CODEDUMPER_LMSTUDIO_PROXY_TARGET=http://127.0.0.1:1234

# Optional. Leave empty and click "Load models" in the UI to select the currently loaded LM Studio model.
VITE_CODEDUMPER_LMSTUDIO_MODEL=google_gemma-4-e4b-it

# Optional. Supported: openai-compatible, ollama-chat, ollama-generate
VITE_CODEDUMPER_LLM_PROVIDER=openai-compatible

# If an old browser session still shows http://127.0.0.1:1234 in the UI,
# click the browser field and set it back to /__codedumper_lmstudio,
# or clear localStorage for the Vite site.
