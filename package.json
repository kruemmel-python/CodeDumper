{
  "name": "codedump-from-zip",
  "private": true,
  "version": "0.0.2-lmstudio-backend-proxy",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:electron": "electron-builder --win",
    "build": "npm run build:web && npm run build:electron",
    "preview": "vite preview",
    "cli": "tsx cli/index.ts",
    "dev:lmstudio": "vite --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "react-dom": "^19.2.0",
    "react": "^19.2.0",
    "minimatch": "9.0.3",
    "jszip": "^3.10.1",
    "js-tiktoken": "^1.0.20",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "electron-squirrel-startup": "^1.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "tsx": "^4.19.2"
  },
  "build": {
    "appId": "com.codedump.desktop",
    "productName": "CodeDump",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "bin": {
    "codedump-from-zip": "./cli/run.mjs"
  }
}